---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
}

const { tr } = Astro.props;
const c = tr.contact;
---

<div class="contact-layout">

  <!-- Form -->
  <div class="contact-form-wrap">
    <!--
      TODO: Regista-te em https://formspree.io e substitui PLACEHOLDER_ID pelo teu form ID.
    -->
    <form
      class="contact-form"
      id="contact-form"
      action="https://formspree.io/f/PLACEHOLDER_ID"
      method="POST"
      novalidate
    >
      <div class="form-row">
        <div class="form-group">
          <label for="cf-name">{c.name}</label>
          <input id="cf-name" type="text" name="name" placeholder={c.namePlaceholder} required autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="cf-email">{c.email}</label>
          <input id="cf-email" type="email" name="email" placeholder={c.emailPlaceholder} required autocomplete="email" />
        </div>
      </div>

      <div class="form-group">
        <label for="cf-subject">{c.subject}</label>
        <input id="cf-subject" type="text" name="subject" placeholder={c.subjectPlaceholder} />
      </div>

      <div class="form-group">
        <label for="cf-message">{c.message}</label>
        <textarea id="cf-message" name="message" rows="6" placeholder={c.messagePlaceholder} required></textarea>
      </div>

      <!-- Feedback states -->
      <div class="form-feedback" id="form-feedback" aria-live="polite" aria-atomic="true"></div>

      <button type="submit" class="btn btn-primary form-submit" id="form-submit">
        <span class="btn-label">{c.send}</span>
        <svg class="btn-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4"/>
        </svg>
        <svg class="btn-spinner" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="8" cy="8" r="6" stroke-dasharray="28" stroke-dashoffset="10"/>
        </svg>
      </button>
    </form>
  </div>

  <!-- Contact info -->
  <aside class="contact-info">

    <div class="ci-block">
      <p class="label">{c.followUs}</p>
      <div class="ci-social">
        <!-- TODO: substituir pelos links reais -->
        <a href="https://www.instagram.com/PLACEHOLDER" target="_blank" rel="noopener" class="ci-social-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          Instagram
        </a>
        <a href="https://www.facebook.com/PLACEHOLDER" target="_blank" rel="noopener" class="ci-social-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
          Facebook
        </a>
      </div>
    </div>

    <div class="ci-block">
      <p class="label">{c.whatsapp}</p>
      <!-- TODO: substituir pelo número real (formato: 351912345678) -->
      <a href="https://wa.me/PLACEHOLDER" target="_blank" rel="noopener" class="btn btn-outline ci-wa-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        WhatsApp
      </a>
    </div>

    <div class="ci-block">
      <p class="label">{c.emailLabel}</p>
      <!-- TODO: substituir pelo email real -->
      <a href="mailto:PLACEHOLDER@email.com" class="ci-email">PLACEHOLDER@email.com</a>
    </div>

  </aside>

</div>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 5rem;
    align-items: start;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
  }

  .form-group input,
  .form-group textarea {
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.875rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--dark);
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
    width: 100%;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder { color: var(--light-gray); }

  .form-group input:focus,
  .form-group textarea:focus { border-color: var(--terracotta); }

  .form-submit { align-self: flex-start; position: relative; min-width: 180px; justify-content: center; }

  /* Spinner (oculto por defeito) */
  .btn-spinner {
    display: none;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Estados do botão */
  .form-submit.is-loading .btn-label { opacity: 0.4; }
  .form-submit.is-loading .btn-icon  { display: none; }
  .form-submit.is-loading .btn-spinner { display: block; }
  .form-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  /* Feedback */
  .form-feedback {
    font-size: 0.88rem;
    padding: 0.875rem 1rem;
    display: none;
    border-left: 3px solid transparent;
  }
  .form-feedback.is-success {
    display: block;
    background: rgba(90, 107, 74, 0.08);
    border-color: #5a6b4a;
    color: #3a4a2a;
  }
  .form-feedback.is-error {
    display: block;
    background: rgba(196, 83, 42, 0.08);
    border-color: var(--terracotta);
    color: var(--terracotta);
  }

  /* Contact info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-top: 0.25rem;
  }

  .ci-block .label { margin-bottom: 1rem; }

  .ci-social {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ci-social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--gray);
    transition: color 0.2s;
  }
  .ci-social-link:hover { color: var(--terracotta); }

  .ci-wa-btn { width: 100%; justify-content: center; }

  .ci-email {
    font-size: 0.85rem;
    color: var(--navy);
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .ci-email:hover { color: var(--terracotta); border-color: var(--terracotta); }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; gap: 3rem; }
    .contact-info { order: -1; }
    .ci-social { flex-direction: row; gap: 1.5rem; }
    .ci-wa-btn { width: auto; }
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form     = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit   = document.getElementById('form-submit') as HTMLButtonElement | null;
  const feedback = document.getElementById('form-feedback') as HTMLElement | null;

  // Mensagens de feedback (PT por defeito — o HTML já está na língua correcta)
  const msg = {
    success: document.documentElement.lang === 'es'
      ? '¡Mensaje enviado! Te responderemos lo antes posible.'
      : document.documentElement.lang === 'en'
        ? 'Message sent! We\'ll get back to you as soon as possible.'
        : 'Mensagem enviada! Entraremos em contacto o mais breve possível.',
    error: document.documentElement.lang === 'es'
      ? 'Ocurrió un error. Por favor inténtalo de nuevo o contáctanos directamente.'
      : document.documentElement.lang === 'en'
        ? 'Something went wrong. Please try again or contact us directly.'
        : 'Ocorreu um erro. Por favor tenta novamente ou contacta-nos diretamente.',
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submit || !feedback) return;

    // Validação básica
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Estado de loading
    submit.classList.add('is-loading');
    submit.disabled = true;
    feedback.className = 'form-feedback';
    feedback.textContent = '';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        feedback.textContent = msg.success;
        feedback.className = 'form-feedback is-success';
        form.reset();
      } else {
        throw new Error('Server error');
      }
    } catch {
      feedback.textContent = msg.error;
      feedback.className = 'form-feedback is-error';
    } finally {
      submit.classList.remove('is-loading');
      submit.disabled = false;
      feedback.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  });
</script>

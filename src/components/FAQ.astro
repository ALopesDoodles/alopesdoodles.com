---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
}

const { tr } = Astro.props;
---

<section class="section faq">
  <div class="container">

    <header class="faq-header">
      <p class="label">{tr.faq.heading}</p>
    </header>

    <div class="faq-list">
      {tr.faq.items.map((item, i) => (
        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-num">0{i + 1}</span>
            <span class="faq-q-text">{item.q}</span>
            <span class="faq-icon" aria-hidden="true">
              <svg class="icon-plus"  width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="7" y1="1" x2="7" y2="13"/><line x1="1" y1="7" x2="13" y2="7"/></svg>
              <svg class="icon-minus" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="1" y1="7" x2="13" y2="7"/></svg>
            </span>
          </summary>
          <div class="faq-answer">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>

  </div>
</section>

<style>
  .faq-header { margin-bottom: 2.5rem; }

  .faq-list {
    border-top: 1px solid var(--border);
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  .faq-question {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .faq-question::-webkit-details-marker { display: none; }

  .faq-num {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    color: var(--terracotta);
    flex-shrink: 0;
    width: 1.5rem;
  }

  .faq-q-text {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--navy);
    flex: 1;
    transition: color 0.2s;
  }
  .faq-item:hover .faq-q-text { color: var(--terracotta); }

  .faq-icon {
    flex-shrink: 0;
    color: var(--terracotta);
    display: flex;
  }
  .icon-minus { display: none; }

  /* Open state */
  .faq-item[open] .icon-plus  { display: none; }
  .faq-item[open] .icon-minus { display: block; }
  .faq-item[open] .faq-q-text { color: var(--terracotta); }

  .faq-answer {
    padding: 0 0 1.75rem calc(1.5rem + 1.25rem);
  }
  .faq-answer p {
    font-size: 0.9rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 52rem;
  }

  @media (max-width: 600px) {
    .faq-num { display: none; }
    .faq-answer { padding-left: 0; }
  }
</style>

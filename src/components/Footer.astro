---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
  lang: string;
}

const { tr, lang } = Astro.props;
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <img src="/logo.png" alt="A.Lopes Doodles" class="footer-logo-img" />
      <p class="footer-tagline">{tr.footer.tagline}</p>
      <p class="footer-location">
        <span class="label">{tr.footer.madeIn}</span>
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={`/${lang}`}>{tr.nav.home}</a>
      <a href={`/${lang}/portfolio`}>{tr.nav.portfolio}</a>
      <a href={`/${lang}/about`}>{tr.nav.about}</a>
      <a href={`/${lang}/contact`}>{tr.nav.contact}</a>
    </nav>

    <div class="footer-social">
      <!-- TODO: substituir pelos links reais -->
      <a href="https://www.instagram.com/PLACEHOLDER" target="_blank" rel="noopener" aria-label="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href="https://www.facebook.com/PLACEHOLDER" target="_blank" rel="noopener" aria-label="Facebook">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>
      <!-- TODO: substituir pelo número real -->
      <a href="https://wa.me/PLACEHOLDER" target="_blank" rel="noopener" aria-label="WhatsApp">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
      </a>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>{tr.footer.rights}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: var(--cream);
    margin-top: auto;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: start;
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 3rem;
  }

  /* Brand */
  .footer-logo-img {
    width: 90px;
    object-fit: contain;
    margin-bottom: 0.75rem;
  }
  .footer-tagline {
    font-size: 0.85rem;
    color: rgba(232, 212, 176, 0.55);
    line-height: 1.6;
    max-width: 26rem;
    margin-bottom: 1.25rem;
  }
  .footer-location .label {
    color: var(--terracotta);
    font-size: 0.6rem;
  }
  .footer-location .label::before {
    background: var(--terracotta);
  }

  /* Nav */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-nav a {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(232, 212, 176, 0.5);
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--cream); }

  /* Social */
  .footer-social {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .footer-social a {
    color: rgba(232, 212, 176, 0.5);
    transition: color 0.2s;
    display: flex;
  }
  .footer-social a:hover { color: var(--terracotta); }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(232, 212, 176, 0.1);
    padding: 1.25rem 0;
  }
  .footer-bottom p {
    font-size: 0.7rem;
    color: rgba(232, 212, 176, 0.3);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-top: 3rem;
    }
    .footer-social { flex-direction: row; }
  }
</style>

---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
}

const { tr } = Astro.props;

// 12 placeholder items — substituir com imagens reais e dados reais
const items = [
  { id: 1,  category: 'printing', color: 'navy',  aspect: '4/3',  title: 'Peça Personalizada #1',  desc: 'Placeholder — PLA, 0.2mm' },
  { id: 2,  category: 'printing', color: 'moss',  aspect: '1/1',  title: 'Miniatura #1',           desc: 'Placeholder — Resina' },
  { id: 3,  category: 'printing', color: 'slate', aspect: '3/4',  title: 'Protótipo #1',           desc: 'Placeholder — PETG' },
  { id: 4,  category: 'printing', color: 'navy',  aspect: '4/3',  title: 'Peça Personalizada #2',  desc: 'Placeholder — PLA' },
  { id: 5,  category: 'laser',    color: 'terra', aspect: '4/3',  title: 'Gravação em Madeira #1', desc: 'Placeholder — MDF 3mm' },
  { id: 6,  category: 'laser',    color: 'warm',  aspect: '1/1',  title: 'Gravação em Acrílico',  desc: 'Placeholder — Acrílico transparente' },
  { id: 7,  category: 'laser',    color: 'slate', aspect: '3/4',  title: 'Gravação em Couro',     desc: 'Placeholder — Couro natural' },
  { id: 8,  category: 'laser',    color: 'terra', aspect: '4/3',  title: 'Gravação em Madeira #2', desc: 'Placeholder — Pinho' },
  { id: 9,  category: 'painting', color: 'cream', aspect: '1/1',  title: 'Miniatura Pintada #1',  desc: 'Placeholder — Acrílico' },
  { id: 10, category: 'painting', color: 'warm',  aspect: '4/3',  title: 'Arte sobre Tela #1',    desc: 'Placeholder — Acrílico sobre tela' },
  { id: 11, category: 'painting', color: 'moss',  aspect: '3/4',  title: 'Miniatura Pintada #2',  desc: 'Placeholder — Óleo' },
  { id: 12, category: 'painting', color: 'cream', aspect: '4/3',  title: 'Arte sobre Tela #2',    desc: 'Placeholder — Técnica mista' },
] as const;
---

<div class="gallery-section">

  <!-- Filter buttons -->
  <div class="filter-bar" role="group" aria-label="Filtrar por categoria">
    <button class="filter-btn active" data-filter="all">{tr.portfolio.filter.all}</button>
    <button class="filter-btn" data-filter="printing">{tr.portfolio.filter.printing}</button>
    <button class="filter-btn" data-filter="laser">{tr.portfolio.filter.laser}</button>
    <button class="filter-btn" data-filter="painting">{tr.portfolio.filter.painting}</button>
  </div>

  <!-- Grid -->
  <div class="gallery-grid" id="gallery-grid">
    {items.map(item => (
      <article class="gallery-item" data-category={item.category}>
        <div class={`ph-img ph-img--${item.color} gi-img`} style={`aspect-ratio: ${item.aspect}`}>
          <span class="ph-img__label">{item.title}</span>
        </div>
        <div class="gi-info">
          <h3 class="gi-title">{item.title}</h3>
          <p class="gi-desc">{item.desc}</p>
        </div>
      </article>
    ))}
  </div>

</div>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      items.forEach(item => {
        const show = filter === 'all' || item.dataset.category === filter;
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  /* Filter bar */
  .filter-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    padding: 0.5rem 1.25rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: transparent;
    color: var(--gray);
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .filter-btn:hover  { border-color: var(--navy); color: var(--navy); }
  .filter-btn.active { background: var(--navy); color: var(--cream); border-color: var(--navy); }

  /* Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .gallery-item { display: flex; flex-direction: column; }

  .gi-img { width: 100%; transition: transform 0.35s ease; }
  .gallery-item:hover .gi-img { transform: scale(1.02); }

  .gi-info {
    padding: 0.875rem 0 0;
  }

  .gi-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 0.25rem;
  }

  .gi-desc {
    font-size: 0.75rem;
    color: var(--light-gray);
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>

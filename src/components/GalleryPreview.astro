---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
  lang: string;
}

const { tr, lang } = Astro.props;

// 6 destaques para a home
const items = [
  { id: 1, src: '/gallery/mini-eu-carocha.png',      category: 'miniEu',       aspect: '1/1', alt: 'Diorama em miniatura com Carocha VW, árvore e banco de jardim' },
  { id: 2, src: '/gallery/mini-eu-casamento.png',     category: 'miniEu',       aspect: '4/3', alt: 'Mini-eu de casal no bolo de casamento' },
  { id: 3, src: '/gallery/mini-eu-ciclista-cao.png',  category: 'miniEu',       aspect: '4/3', alt: 'Mini-eu de ciclista MTB com bicicleta e cão em diorama' },
  { id: 4, src: '/gallery/col-rei-trono.png',         category: 'collectibles', aspect: '1/1', alt: 'Estatueta coleccionável de rei em trono dourado' },
  { id: 5, src: '/gallery/col-michael-jackson.png',   category: 'collectibles', aspect: '3/4', alt: 'Estatueta coleccionável de Michael Jackson pintada à mão' },
  { id: 6, src: '/gallery/mini-eu-guarda-redes.png',  category: 'miniEu',       aspect: '4/3', alt: 'Mini-eu personalizado de guarda-redes Martim com baliza' },
] as const;

const categoryLabel = (cat: string) => {
  const map: Record<string, string> = {
    miniEu:       tr.portfolio.filter.miniEu,
    laser:        tr.portfolio.filter.laser,
    tabletop:     tr.portfolio.filter.tabletop,
    collectibles: tr.portfolio.filter.collectibles,
  };
  return map[cat] ?? cat;
};
---

<section class="section gallery-preview" aria-labelledby="gallery-preview-heading">
  <div class="container">

    <header class="gp-header">
      <div>
        <p class="label">{tr.portfolio.heading}</p>
        <h2 class="section-title" id="gallery-preview-heading">{tr.portfolio.subheading}</h2>
      </div>
      <a href={`/${lang}/portfolio`} class="btn btn-outline gp-view-all">
        {tr.portfolio.viewAll}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4"/>
        </svg>
      </a>
    </header>

    <ul class="gp-grid" role="list">
      {items.map(item => (
        <li role="listitem">
          <a href={`/${lang}/portfolio`} class="gp-item" aria-label={item.alt}>
            <img
              src={item.src}
              alt={item.alt}
              class="gp-img"
              loading="lazy"
              style={`aspect-ratio: ${item.aspect}`}
            />
            <div class="gp-overlay" aria-hidden="true">
              <span class="gp-category">{categoryLabel(item.category)}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .gp-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  .gp-header .label { margin-bottom: 0.5rem; }
  .gp-view-all { align-self: flex-end; flex-shrink: 0; }

  .gp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .gp-item {
    display: block;
    position: relative;
    overflow: hidden;
  }
  .gp-item:focus-visible {
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }

  .gp-img { width: 100%; transition: transform 0.4s ease; }

  .gp-overlay {
    position: absolute;
    inset: 0;
    background: rgba(28, 36, 56, 0.35);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    transition: background 0.3s;
  }

  .gp-category {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: white;
    transition: opacity 0.3s;
  }

  /* Dispositivos com hover real (rato) — efeito dinâmico */
  @media (hover: hover) {
    .gp-overlay { background: rgba(28, 36, 56, 0); }
    .gp-category { opacity: 0; transform: translateY(4px); transition: opacity 0.3s, transform 0.3s; }
    .gp-item:hover .gp-img { transform: scale(1.03); }
    .gp-item:hover .gp-overlay { background: rgba(28, 36, 56, 0.4); }
    .gp-item:hover .gp-category { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .gp-header { flex-direction: column; align-items: flex-start; }
    .gp-grid   { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .gp-grid { grid-template-columns: 1fr; }
  }
</style>

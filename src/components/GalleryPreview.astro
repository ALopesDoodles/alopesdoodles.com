---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
  lang: string;
}

const { tr, lang } = Astro.props;

// 6 placeholder items para a home — substituir com imagens reais
const items = [
  { id: 1, category: 'printing', color: 'navy',  aspect: '4/3',  title: 'Projeto 3D #1' },
  { id: 2, category: 'laser',    color: 'terra', aspect: '1/1',  title: 'Gravação #1'   },
  { id: 3, category: 'painting', color: 'cream', aspect: '4/3',  title: 'Pintura #1'    },
  { id: 4, category: 'laser',    color: 'slate', aspect: '1/1',  title: 'Gravação #2'   },
  { id: 5, category: 'printing', color: 'moss',  aspect: '4/3',  title: 'Projeto 3D #2' },
  { id: 6, category: 'painting', color: 'warm',  aspect: '1/1',  title: 'Pintura #2'    },
] as const;
---

<section class="section gallery-preview">
  <div class="container">

    <header class="gp-header">
      <div>
        <p class="label">{tr.portfolio.heading}</p>
        <h2 class="section-title">{tr.portfolio.subheading}</h2>
      </div>
      <a href={`/${lang}/portfolio`} class="btn btn-outline gp-view-all">
        {tr.portfolio.viewAll}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 7h10M8 3l4 4-4 4"/>
        </svg>
      </a>
    </header>

    <div class="gp-grid">
      {items.map(item => (
        <a href={`/${lang}/portfolio`} class="gp-item" aria-label={item.title}>
          <div
            class={`ph-img ph-img--${item.color} gp-img`}
            style={`aspect-ratio: ${item.aspect}`}
          >
            <span class="ph-img__label">{item.title}</span>
          </div>
          <div class="gp-overlay">
            <span class="gp-category">
              {item.category === 'printing' ? tr.portfolio.filter.printing
               : item.category === 'laser' ? tr.portfolio.filter.laser
               : tr.portfolio.filter.painting}
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .gp-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  .gp-header .label { margin-bottom: 0.5rem; }
  .gp-view-all { align-self: flex-end; }

  .gp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .gp-item {
    display: block;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .gp-img { width: 100%; transition: transform 0.4s ease; }
  .gp-item:hover .gp-img { transform: scale(1.03); }

  .gp-overlay {
    position: absolute;
    inset: 0;
    background: rgba(28, 36, 56, 0);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    transition: background 0.3s;
  }
  .gp-item:hover .gp-overlay { background: rgba(28, 36, 56, 0.4); }

  .gp-category {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: white;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s, transform 0.3s;
  }
  .gp-item:hover .gp-category { opacity: 1; transform: translateY(0); }

  @media (max-width: 768px) {
    .gp-header { flex-direction: column; align-items: flex-start; }
    .gp-grid   { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .gp-grid { grid-template-columns: 1fr; }
  }
</style>

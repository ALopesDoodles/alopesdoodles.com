---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
  lang: string;
}

const { tr, lang } = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container hero-inner">

    <div class="hero-content">
      <p class="label hero-badge">{tr.hero.badge}</p>

      <h1 class="hero-title" id="hero-title">
        <span class="hero-title-main">A.Lopes</span>
        <span class="hero-title-accent">Doodles</span>
      </h1>

      <p class="hero-tagline">{tr.hero.tagline}</p>
      <p class="hero-subtitle">{tr.hero.subtitle}</p>

      <div class="hero-cta">
        <a href={`/${lang}/portfolio`} class="btn btn-primary">{tr.hero.cta}</a>
        <a href={`/${lang}/contact`} class="btn btn-outline">{tr.hero.ctaSecondary}</a>
      </div>
    </div>

    <div class="hero-deco" aria-hidden="true">
      <img src="/logo.png" alt="" aria-hidden="true" class="hero-logo-img" />
    </div>

  </div>

  <hr class="divider" />
</section>

<style>
  .hero {
    min-height: calc(90vh - var(--header-h));
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    padding-top: var(--section-py);
    padding-bottom: var(--section-py);
  }

  .hero-badge { margin-bottom: 2rem; }

  .hero-title {
    display: flex;
    flex-direction: column;
    font-family: var(--font-serif);
    font-weight: 400;
    line-height: 1.02;
    margin-bottom: 1.75rem;
  }
  .hero-title-main  { font-size: clamp(3.5rem, 7vw, 6.5rem); color: var(--navy); }
  .hero-title-accent{ font-size: clamp(3rem, 6vw, 5.5rem); font-style: italic; color: var(--terracotta); }

  .hero-tagline {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-style: italic;
    color: var(--navy);
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .hero-subtitle {
    font-size: clamp(0.88rem, 1.6vw, 0.97rem);
    color: var(--gray);
    max-width: 38rem;
    margin-bottom: 2.5rem;
    line-height: 1.75;
  }

  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hero-deco { display: flex; justify-content: center; align-items: center; }

  .hero-logo-img {
    width: clamp(260px, 30vw, 400px);
    aspect-ratio: 1;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-badge, .hero-tagline { display: block; }
    .hero-subtitle { margin-left: auto; margin-right: auto; }
    .hero-cta { justify-content: center; }
    .hero-deco { order: -1; }
    .hero-logo-img { width: clamp(180px, 45vw, 260px); }
  }
</style>

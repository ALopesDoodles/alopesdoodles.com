---
import type { Translations } from '../i18n/translations';

interface Props {
  tr: Translations;
  lang: string;
}

const { tr, lang } = Astro.props;

const services = [
  {
    key: 'printing',
    number: '01',
    data: tr.services.printing,
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="8" y="20" width="24" height="14" rx="1"/>
      <path d="M8 24V10a2 2 0 0 1 2-2h20a2 2 0 0 1 2 2v14"/>
      <rect x="14" y="28" width="12" height="6"/>
      <circle cx="30" cy="22" r="1.5" fill="currentColor" stroke="none"/>
    </svg>`,
  },
  {
    key: 'laser',
    number: '02',
    data: tr.services.laser,
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="20" cy="20" r="4"/>
      <line x1="20" y1="6" x2="20" y2="12"/>
      <line x1="20" y1="28" x2="20" y2="34"/>
      <line x1="6" y1="20" x2="12" y2="20"/>
      <line x1="28" y1="20" x2="34" y2="20"/>
      <line x1="10.1" y1="10.1" x2="14.2" y2="14.2"/>
      <line x1="25.8" y1="25.8" x2="29.9" y2="29.9"/>
      <line x1="29.9" y1="10.1" x2="25.8" y2="14.2"/>
      <line x1="14.2" y1="25.8" x2="10.1" y2="29.9"/>
    </svg>`,
  },
  {
    key: 'painting',
    number: '03',
    data: tr.services.painting,
    icon: `<svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 32 L26 10 L30 14 L14 36 Q8 38 10 32Z"/>
      <line x1="22" y1="14" x2="26" y2="18"/>
      <path d="M30 8 a2 2 0 0 1 2 2" stroke-width="2"/>
    </svg>`,
  },
] as const;
---

<section class="section services">
  <div class="container">

    <header class="services-header">
      <p class="label">{tr.services.heading}</p>
    </header>

    <div class="services-grid">
      {services.map(service => (
        <article class="service-card">
          <p class="service-number">{service.number}</p>
          <div class="service-icon" set:html={service.icon} />
          <h3 class="service-name">{service.data.label}</h3>
          <p class="service-desc">{service.data.description}</p>
        </article>
      ))}
    </div>

    <div class="services-cta">
      <a href={`/${lang}/portfolio`} class="btn btn-outline">
        {tr.portfolio.viewAll}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 7h10M8 3l4 4-4 4"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .services-header {
    margin-bottom: 3.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .service-card {
    background: var(--off-white);
    padding: 3rem 2.5rem;
    transition: background 0.2s;
  }
  .service-card:hover { background: #fff; }

  .service-number {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--terracotta);
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .service-icon {
    color: var(--navy);
    margin-bottom: 1.5rem;
    opacity: 0.85;
  }

  .service-name {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 0.875rem;
  }

  .service-desc {
    font-size: 0.88rem;
    color: var(--gray);
    line-height: 1.75;
  }

  .services-cta {
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
    .services-cta { justify-content: flex-start; }
    .service-card { padding: 2rem 1.5rem; }
  }
</style>

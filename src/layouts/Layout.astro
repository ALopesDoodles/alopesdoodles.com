---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'A.Lopes Doodles',
  description = 'Impressão 3D, Gravação Laser e Pintura. Trabalhos elaborados por quem ama o que faz. Feito em Portugal.',
  lang = 'pt',
} = Astro.props;

const pageTitle = title === 'A.Lopes Doodles' ? title : `${title} | A.Lopes Doodles`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

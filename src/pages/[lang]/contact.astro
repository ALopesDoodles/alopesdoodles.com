---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import { t } from '../../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'pt' } },
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const tr = t(lang);
const c = tr.contact;
---

<Layout lang={lang} title={tr.seo.contact.title} description={tr.seo.contact.description} canonicalPath={`/${lang}/contact`}>
  <Header lang={lang} currentPage="contact" tr={tr} />
  <main id="main-content" tabindex="-1">

    <section class="section page-hero">
      <div class="container">
        <p class="label">{c.heading}</p>
        <h1 class="section-title">{c.subheading}</h1>
      </div>
    </section>
    <hr class="divider" />

    <section class="section">
      <div class="container">
        <ContactForm tr={tr} />
      </div>
    </section>

  </main>
  <Footer tr={tr} lang={lang} />
</Layout>

<style>
  .page-hero { padding-bottom: 3rem; }
  .page-hero .label { margin-bottom: 0.75rem; }
</style>
